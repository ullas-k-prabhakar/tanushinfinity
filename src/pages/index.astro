---
import '../styles.css';
---
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Tanush Infinity | Home Construction Hardwares</title>
    <meta
      name="description"
      content="Tanush Infinity delivers premium hardware for home construction, renovation, and repair projects."
    />
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <div class="brand">
          <span class="brand-mark">TI</span>
          <div>
            <h1>Tanush Infinity</h1>
            <p>Quality hardware for every home build</p>
          </div>
        </div>
        <nav class="nav-links">
          <a href="#products">Products</a>
          <a href="#services">Services</a>
          <a href="#contact">Contact.</a>
        </nav>
        <button class="menu-toggle" aria-label="Open menu">☰</button>
      </div>
    </header>

    <main>
      <section class="hero">
        <div class="container hero-grid">
          <div class="hero-copy">
            <p class="eyebrow">Build smart. Build strong.</p>
            <h2>Tanush Infinity for home construction hardware</h2>
            <p>
              Reliable tools, durable fixtures, and premium materials designed for builders,
              renovators, and homeowners.
            </p>
            <div class="hero-actions">
              <a href="#products" class="btn btn-primary">Browse products</a>
              <a href="#contact" class="btn btn-secondary">Get a quote</a>
            </div>
          </div>
          <div class="hero-image">
            <div class="hero-card">
              <h3>Featured range</h3>
              <p>
                Doors, fasteners, tools, electrical fittings, plumbing hardware, and safety
                essentials.blah blah blahhhhh
              </p>
              <div class="hero-stats">
                <div>
                  <strong>3000+</strong>
                  <span>Items in stock</span>
                </div>
                <div>
                  <strong>24/7</strong>
                  <span>Support</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="products" class="section-light">
        <div class="container">
          <div class="section-intro">
            <p class="eyebrow">Top categories</p>
            <h2>Hardware built for every stage</h2>
          </div>
          <div class="cards-grid">
            <article class="card">
              <h3>Tools & Equipment</h3>
              <p>Power tools, hand tools, measuring gear, and everything your crew needs on site.</p>
            </article>
            <article class="card">
              <h3>Doors & Fixtures</h3>
              <p>Door handles, hinges, locks, and fittings made for durability and style.</p>
            </article>
            <article class="card">
              <h3>Electrical Supplies</h3>
              <p>Wiring, switches, sockets, lighting components, and safety accessories.</p>
            </article>
            <article class="card">
              <h3>Plumbing Hardware</h3>
              <p>Pipes, valves, faucets, and connectors for reliable water systems.</p>
            </article>
          </div>
        </div>
      </section>

      <section id="services" class="section-dark">
        <div class="container">
          <div class="section-intro light">
            <p class="eyebrow">What we offer</p>
            <h2>Fast delivery and expert support</h2>
          </div>
          <div class="services-grid">
            <div class="service-card">
              <h3>Project consultation</h3>
              <p>Get guidance on selecting the right hardware for home renovations, new builds, and upgrades.</p>
            </div>
            <div class="service-card">
              <h3>Customized supply</h3>
              <p>Flexible orders for contractors, designers, and homeowners with reliable sourcing.</p>
            </div>
            <div class="service-card">
              <h3>Secure pricing</h3>
              <p>Transparent quotes and pricing so you can plan your project without surprises.</p>
            </div>
          </div>
        </div>
      </section>

      <section id="contact" class="section-light contact-section">
        <div class="container contact-grid">
          <div>
            <p class="eyebrow">Contact us</p>
            <h2>Ready to start your next build?</h2>
            <p>Reach out for product details, pricing, or custom order support.</p>
            <ul class="contact-list">
              <li><strong>Email:</strong> hello@tanushinfinity.com</li>
              <li><strong>Phone:</strong> +91 98765 43210</li>
              <li><strong>Location:</strong> Home construction hardware supplies, India</li>
            </ul>
          </div>
          <form class="contact-form" action="#" method="post">
            <label>
              Your name
              <input type="text" name="name" placeholder="Enter your name" required />
            </label>
            <label>
              Email address
              <input type="email" name="email" placeholder="you@example.com" required />
            </label>
            <label>
              Message
              <textarea name="message" rows="5" placeholder="Tell us about your project" required></textarea>
            </label>
            <button type="submit" class="btn btn-primary">Send message</button>
          </form>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <p>&copy; 2026 Tanush Infinity. Built for modern home construction hardware.</p>
        <p>Responsive design for mobile and desktop.</p>
      </div>
    </footer>
  </body>
</html>
